generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum AdminGroupRole {
  OWNER
  SCHEDULER
  REVIEWER
  VIEWER
}

enum AdminStatus {
  ACTIVE
  DISABLED
}

enum InterviewGroupStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum InterviewProjectStatus {
  ACTIVE
  ARCHIVED
}

enum InterviewRoundStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum InterviewerStatus {
  ACTIVE
  INACTIVE
}

enum GroupTimeSlotStatus {
  OPEN
  CLOSED
}

enum TimeSlotLockType {
  APPOINTMENT
  MANUAL
}

enum CandidateStatus {
  SUBMITTED
  PENDING_REVIEW
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CandidateSubmissionType {
  INITIAL
  MODIFICATION
}

enum CandidateSubmissionStatus {
  ACTIVE
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
}

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum CandidateAdminNoteVisibility {
  ADMIN_ONLY
}

enum AdminNotificationType {
  MODIFICATION_REVIEW
  SYSTEM
}

enum AdminNotificationStatus {
  UNREAD
  READ
  HANDLED
}

enum AuditActorType {
  ADMIN
  CANDIDATE
  SYSTEM
}

enum CandidateEmailDeliveryStatus {
  PROCESSING
  SENT
  PREVIEW
  FAILED
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model Admin {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  displayName  String
  role         AdminRole   @default(SUPER_ADMIN)
  status       AdminStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?

  sessions              AdminSession[]
  groupMemberships      AdminGroupMembership[]
  createdProjects       InterviewProject[]       @relation("ProjectCreator")
  createdGroups         InterviewGroup[]         @relation("GroupCreator")
  reviewedSubmissions   CandidateSubmission[]    @relation("SubmissionReviewer")
  scheduledAppointments Appointment[]            @relation("AppointmentScheduler")
  cancelledAppointments Appointment[]            @relation("AppointmentCanceller")
  writtenCandidateNotes CandidateAdminNote[]     @relation("CandidateAdminNoteAuthor")
  notifications         AdminNotification[]      @relation("AdminNotificationRecipient")
  lockedSlots           TimeSlotLock[]           @relation("SlotLocker")
  adminAuditLogs        AuditLog[]               @relation("AuditAdminActor")
  sentCandidateEmails   CandidateEmailDelivery[] @relation("CandidateEmailSender")
  updatedEmailTemplates EmailTemplate[]          @relation("EmailTemplateUpdater")

  @@index([role, status])
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model InterviewProject {
  id                String                 @id @default(cuid())
  name              String
  publicDescription String?
  status            InterviewProjectStatus @default(ACTIVE)
  createdByAdminId  String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  createdByAdmin Admin            @relation("ProjectCreator", fields: [createdByAdminId], references: [id])
  rounds         InterviewRound[]
  groups         InterviewGroup[]
  interviewers   Interviewer[]

  @@index([createdByAdminId])
  @@index([status])
}

model InterviewRound {
  id                       String               @id @default(cuid())
  projectId                String
  name                     String
  orderIndex               Int                  @default(1)
  description              String?
  interviewDurationMinutes Int?
  status                   InterviewRoundStatus @default(ACTIVE)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  project      InterviewProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groups       InterviewGroup[]
  appointments Appointment[]

  @@unique([projectId, orderIndex])
  @@index([projectId, status])
}

model Interviewer {
  id              String            @id @default(cuid())
  projectId       String
  name            String
  email           String
  normalizedEmail String
  status          InterviewerStatus @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project          InterviewProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appointmentLinks AppointmentInterviewer[]

  @@unique([projectId, normalizedEmail])
  @@index([projectId, status])
}

model InterviewGroup {
  id                         String               @id @default(cuid())
  projectId                  String?
  roundId                    String?
  name                       String
  groupCode                  String               @unique
  publicDescription          String?
  timezone                   String               @default("Asia/Shanghai")
  status                     InterviewGroupStatus @default(DRAFT)
  slotDurationMinutes        Int                  @default(60)
  interviewDurationMinutes   Int                  @default(30)
  minSelectSlots             Int                  @default(1)
  maxSelectSlots             Int                  @default(6)
  allowCandidateNote         Boolean              @default(true)
  modificationRequiresReview Boolean              @default(true)
  autoLockBookedSlots        Boolean              @default(true)
  createdByAdminId           String
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  project               InterviewProject?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  round                 InterviewRound?          @relation(fields: [roundId], references: [id], onDelete: SetNull)
  createdByAdmin        Admin                    @relation("GroupCreator", fields: [createdByAdminId], references: [id])
  adminMemberships      AdminGroupMembership[]
  timeSlots             GroupTimeSlot[]
  locks                 TimeSlotLock[]
  candidates            Candidate[]
  candidateAccessTokens CandidateAccessToken[]
  candidateSessions     CandidateSession[]
  submissions           CandidateSubmission[]
  appointments          Appointment[]
  adminNotes            CandidateAdminNote[]
  notifications         AdminNotification[]
  auditLogs             AuditLog[]
  emailDeliveries       CandidateEmailDelivery[]

  @@index([createdByAdminId])
  @@index([projectId])
  @@index([roundId])
  @@index([status])
}

model AdminGroupMembership {
  id        String         @id @default(cuid())
  adminId   String
  groupId   String
  role      AdminGroupRole @default(VIEWER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  admin Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  group InterviewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([adminId, groupId])
  @@index([groupId, role])
  @@index([adminId, role])
}

model GroupTimeSlot {
  id           String              @id @default(cuid())
  groupId      String
  startAt      DateTime
  endAt        DateTime
  status       GroupTimeSlotStatus @default(OPEN)
  internalNote String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  group            InterviewGroup            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  locks            TimeSlotLock[]            @relation("SlotLocks")
  activeLock       TimeSlotLock?             @relation("ActiveSlotLock")
  submissionSlots  CandidateSubmissionSlot[]
  appointmentSlots AppointmentSlot[]

  @@unique([groupId, startAt, endAt])
  @@index([groupId, status, startAt])
}

model TimeSlotLock {
  id              String           @id @default(cuid())
  groupId         String
  slotId          String
  activeSlotId    String?          @unique
  lockType        TimeSlotLockType
  appointmentId   String?
  reasonInternal  String?
  lockedByAdminId String?
  createdAt       DateTime         @default(now())
  releasedAt      DateTime?

  group         InterviewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  slot          GroupTimeSlot  @relation("SlotLocks", fields: [slotId], references: [id], onDelete: Cascade)
  activeSlot    GroupTimeSlot? @relation("ActiveSlotLock", fields: [activeSlotId], references: [id], onDelete: SetNull)
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  lockedByAdmin Admin?         @relation("SlotLocker", fields: [lockedByAdminId], references: [id], onDelete: SetNull)

  @@index([groupId, slotId])
  @@index([appointmentId])
  @@index([releasedAt])
}

model Candidate {
  id                 String          @id @default(cuid())
  groupId            String
  name               String
  email              String
  normalizedEmail    String
  status             CandidateStatus @default(SUBMITTED)
  activeSubmissionId String?         @unique
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  group              InterviewGroup            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  activeSubmission   CandidateSubmission?      @relation("CandidateActiveSubmission", fields: [activeSubmissionId], references: [id], onDelete: SetNull)
  submissions        CandidateSubmission[]     @relation("CandidateSubmissions")
  submissionSlots    CandidateSubmissionSlot[]
  appointments       Appointment[]
  adminNotes         CandidateAdminNote[]
  notifications      AdminNotification[]
  candidateAuditLogs AuditLog[]                @relation("AuditCandidateActor")
  emailDeliveries    CandidateEmailDelivery[]
  sessions           CandidateSession[]

  @@unique([groupId, normalizedEmail])
  @@index([groupId, status])
}

model CandidateAccessToken {
  id              String    @id @default(cuid())
  groupId         String
  tokenHash       String    @unique
  name            String
  email           String
  normalizedEmail String
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())

  group InterviewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, normalizedEmail])
  @@index([expiresAt])
}

model CandidateSession {
  id              String   @id @default(cuid())
  groupId         String
  candidateId     String?
  tokenHash       String   @unique
  name            String
  email           String
  normalizedEmail String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  group     InterviewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  candidate Candidate?     @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([groupId, normalizedEmail])
  @@index([candidateId])
  @@index([expiresAt])
}

model CandidateSubmission {
  id                       String                    @id @default(cuid())
  candidateId              String
  pendingReviewCandidateId String?                   @unique
  groupId                  String
  versionNo                Int
  submissionType           CandidateSubmissionType
  candidateNameSnapshot    String
  candidateEmailSnapshot   String
  candidateNote            String?
  status                   CandidateSubmissionStatus
  submittedAt              DateTime                  @default(now())
  reviewedByAdminId        String?
  reviewedAt               DateTime?
  reviewComment            String?
  createdAt                DateTime                  @default(now())

  candidate          Candidate                 @relation("CandidateSubmissions", fields: [candidateId], references: [id], onDelete: Cascade)
  activeForCandidate Candidate?                @relation("CandidateActiveSubmission")
  group              InterviewGroup            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reviewedByAdmin    Admin?                    @relation("SubmissionReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  slots              CandidateSubmissionSlot[]
  notifications      AdminNotification[]

  @@unique([candidateId, versionNo])
  @@index([groupId, status])
  @@index([candidateId, status])
}

model CandidateSubmissionSlot {
  id           String   @id @default(cuid())
  submissionId String
  candidateId  String
  groupId      String
  slotId       String
  createdAt    DateTime @default(now())

  submission CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  candidate  Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  slot       GroupTimeSlot       @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([submissionId, slotId])
  @@index([candidateId])
  @@index([groupId, slotId])
}

model Appointment {
  id                      String            @id @default(cuid())
  groupId                 String
  roundId                 String?
  candidateId             String
  startAt                 DateTime
  endAt                   DateTime
  status                  AppointmentStatus @default(SCHEDULED)
  candidateVisibleMessage String?
  meetingLocation         String?
  internalNote            String?
  scheduledByAdminId      String
  scheduledAt             DateTime          @default(now())
  cancelledByAdminId      String?
  cancelledAt             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  group            InterviewGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  round            InterviewRound?          @relation(fields: [roundId], references: [id], onDelete: SetNull)
  candidate        Candidate                @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  scheduledByAdmin Admin                    @relation("AppointmentScheduler", fields: [scheduledByAdminId], references: [id])
  cancelledByAdmin Admin?                   @relation("AppointmentCanceller", fields: [cancelledByAdminId], references: [id], onDelete: SetNull)
  slots            AppointmentSlot[]
  locks            TimeSlotLock[]
  interviewers     AppointmentInterviewer[]

  @@index([groupId, status, startAt])
  @@index([roundId, status, startAt])
  @@index([candidateId, status])
}

model AppointmentSlot {
  id            String   @id @default(cuid())
  appointmentId String
  slotId        String
  createdAt     DateTime @default(now())

  appointment Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  slot        GroupTimeSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, slotId])
  @@index([slotId])
}

model AppointmentInterviewer {
  id            String   @id @default(cuid())
  appointmentId String
  interviewerId String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  interviewer Interviewer @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, interviewerId])
  @@index([interviewerId])
}

model CandidateAdminNote {
  id            String                       @id @default(cuid())
  groupId       String
  candidateId   String
  authorAdminId String
  body          String
  visibility    CandidateAdminNoteVisibility @default(ADMIN_ONLY)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  group       InterviewGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  candidate   Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorAdmin Admin          @relation("CandidateAdminNoteAuthor", fields: [authorAdminId], references: [id])

  @@index([groupId, candidateId])
  @@index([authorAdminId])
}

model AdminNotification {
  id               String                  @id @default(cuid())
  recipientAdminId String?
  groupId          String
  candidateId      String?
  submissionId     String?
  type             AdminNotificationType
  title            String
  content          String
  status           AdminNotificationStatus @default(UNREAD)
  createdAt        DateTime                @default(now())
  handledAt        DateTime?

  recipientAdmin Admin?               @relation("AdminNotificationRecipient", fields: [recipientAdminId], references: [id], onDelete: SetNull)
  group          InterviewGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  candidate      Candidate?           @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  submission     CandidateSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([recipientAdminId, status])
  @@index([groupId, type])
}

model CandidateEmailDelivery {
  id                     String                       @id @default(cuid())
  groupId                String
  candidateId            String
  sentByAdminId          String
  batchId                String
  templateKey            String?
  subject                String
  bodyTemplate           String
  renderedSubject        String?
  renderedBody           String?
  candidateNameSnapshot  String
  recipientEmailSnapshot String
  ccEmailSnapshots       String[]                     @default([])
  status                 CandidateEmailDeliveryStatus
  idempotencyKey         String?                      @unique
  providerMessageId      String?
  errorMessage           String?
  leaseExpiresAt         DateTime?
  retriedFromId          String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  group       InterviewGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  candidate   Candidate                @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  sentByAdmin Admin                    @relation("CandidateEmailSender", fields: [sentByAdminId], references: [id])
  retriedFrom CandidateEmailDelivery?  @relation("CandidateEmailRetry", fields: [retriedFromId], references: [id], onDelete: SetNull)
  retries     CandidateEmailDelivery[] @relation("CandidateEmailRetry")

  @@index([groupId, createdAt])
  @@index([candidateId, createdAt])
  @@index([sentByAdminId])
  @@index([batchId])
  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
}

model EmailTemplate {
  id               String   @id @default(cuid())
  key              String   @unique
  label            String
  subject          String
  body             String
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  updatedByAdmin Admin? @relation("EmailTemplateUpdater", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  @@index([updatedByAdminId])
}

model EmailOutbox {
  id            String            @id @default(cuid())
  status        EmailOutboxStatus @default(PENDING)
  type          String
  payload       Json
  attempts      Int               @default(0)
  maxAttempts   Int               @default(3)
  lastError     String?
  nextAttemptAt DateTime          @default(now())
  leaseExpiresAt DateTime?
  processedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, nextAttemptAt])
  @@index([status, leaseExpiresAt])
  @@index([type, createdAt])
}

/// Shared, short-lived fixed-window counters used for unauthenticated and
/// login abuse controls. Keys are one-way hashes where they contain any
/// client identity, never raw emails or IP addresses.
model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model AuditLog {
  id               String         @id @default(cuid())
  actorType        AuditActorType
  actorAdminId     String?
  actorCandidateId String?
  groupId          String?
  action           String
  entityType       String
  entityId         String
  beforeData       Json?
  afterData        Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime       @default(now())

  actorAdmin     Admin?          @relation("AuditAdminActor", fields: [actorAdminId], references: [id], onDelete: SetNull)
  actorCandidate Candidate?      @relation("AuditCandidateActor", fields: [actorCandidateId], references: [id], onDelete: SetNull)
  group          InterviewGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([actorType, createdAt])
  @@index([entityType, entityId])
  @@index([groupId, createdAt])
}
