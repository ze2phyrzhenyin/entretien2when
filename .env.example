DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_scheduler_cn?schema=public"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_PATH=""
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_PASSWORD="ChangeMe_StrongPassword_123!"
ADMIN_BOOTSTRAP_NAME="超级管理员"
SESSION_TTL_DAYS="7"
SESSION_COOKIE_SECURE="false"
