CANDIDATE_SESSION_TTL_DAYS="14"
CANDIDATE_AUTH_DEV_PREVIEW="false"
MAILATO_COMMAND="mailato"
MAILATO_DRY_RUN="true"
EMAIL_OUTBOX_BATCH_SIZE="20"
